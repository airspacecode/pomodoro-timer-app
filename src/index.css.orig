/* Work session theme (default) */
:root,
.theme-work {
  --bg: #1a1a2e;
  --surface: #16213e;
  --surface-border: #2a2d4a;
  --surface-hover: #323566;
  --text-primary: #e2e8f0;
  --text-secondary: #94a3b8;
  --text-muted: #64748b;
  --accent: #e74c3c;
  --accent-hover: #c0392b;
  --accent-glow: rgba(231, 76, 60, 0.35);
  --accent-text: #ffffff;
  --accent-break: #27ae60;
  --accent-long: #2980b9;
}

/* Short break theme */
.theme-short-break {
  --bg: #0d2818;
  --surface: #0a1f12;
  --surface-border: #1a3d25;
  --surface-hover: #245232;
  --accent: #27ae60;
  --accent-hover: #219a52;
  --accent-glow: rgba(39, 174, 96, 0.35);
}

/* Long break theme */
.theme-long-break {
  --bg: #0d1f35;
  --surface: #0a1626;
  --surface-border: #1a3050;
  --surface-hover: #1e3d66;
  --accent: #2980b9;
  --accent-hover: #2471a3;
  --accent-glow: rgba(41, 128, 185, 0.35);
}

